---
import "../styles/global.css";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.15.2/dist/katex.min.css"
      integrity="sha384-MlJdn/WNKDGXveldHDdyRP1R4CTHr3FeuDNfhsLPYrq2t0UBkUdK2jyTnXPEK1NQ"
      crossorigin="anonymous"
    />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="4cded9dd-3b5f-4e01-8b63-7e8ef49cc9b5"></script>
    <title>rudyon.io</title>
  </head>
  <body class="bg-dr">
    <header class="flex flex-wrap p-4 overflow-x-hidden">
      <Header />
    </header>

    <main class="text-white font-[Ovo]">
      <slot />
    </main>

    <footer class="text-white font-[Ovo] p-2 text-center">
      <p>rudyon © 2024-2025</p>
    </footer>
  </body>
</html>
